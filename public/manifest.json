{
    "manifest_version": 3,
    "name": "__MSG_extName__",
    "version": "3.6",
    "description": "__MSG_extDescription__",
    "author": "codellyson <isiakalukmandellyson@gmail.com>",
    "background": {
        "service_worker": "background.js"
    },
    "options_page": "options.html",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_icon": {
            "24": "img/icon24.png",
            "32": "img/icon32.png",
            "48": "img/icon48.png",
            "128": "img/icon128.png"
        },
        "default_title": "__MSG_actionTitle__"
    },
    "default_locale": "en",
    "icons": {
        "48": "img/icon48.png",
        "64": "img/icon64.png",
        "128": "img/icon128.png"
    },
    "minimum_chrome_version": "92"
}
